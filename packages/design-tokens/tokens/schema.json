{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/dtcg-structure.schema.json",
  "title": "DTCG Design Tokens – Structure-only Schema",
  "description": "Validates token/group structure and $type enum. Does NOT validate $value contents — use `npm run validate` for programmatic validation including $type inheritance resolution.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor tooling"
    },
    "$description": { "type": "string" },
    "$type": { "$ref": "#/$defs/typeEnum" },
    "$deprecated": { "oneOf": [{ "type": "boolean" }, { "type": "string" }] },
    "$extensions": { "type": "object" }
  },
  "patternProperties": {
    "^(?!\\$)[^{}.]+$": {
      "description": "Token or group key: must NOT start with $, nor contain { } .",
      "oneOf": [{ "$ref": "#/$defs/token" }, { "$ref": "#/$defs/group" }]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "group": {
      "type": "object",
      "properties": {
        "$description": { "type": "string" },
        "$type": { "$ref": "#/$defs/typeEnum" },
        "$deprecated": {
          "oneOf": [{ "type": "boolean" }, { "type": "string" }]
        },
        "$extensions": { "type": "object" }
      },
      "patternProperties": {
        "^(?!\\$)[^{}.]+$": {
          "oneOf": [{ "$ref": "#/$defs/token" }, { "$ref": "#/$defs/group" }]
        }
      },
      "additionalProperties": false
    },
    "token": {
      "type": "object",
      "properties": {
        "$description": { "type": "string" },
        "$type": { "$ref": "#/$defs/typeEnum" },
        "$deprecated": {
          "oneOf": [{ "type": "boolean" }, { "type": "string" }]
        },
        "$extensions": { "type": "object" },
        "$value": true
      },
      "required": ["$value"],
      "additionalProperties": false
    },
    "typeEnum": {
      "type": "string",
      "enum": [
        "color",
        "dimension",
        "fontFamily",
        "fontWeight",
        "duration",
        "cubicBezier",
        "number",
        "strokeStyle",
        "border",
        "transition",
        "shadow",
        "gradient",
        "typography",
        "cssImport"
      ]
    }
  }
}
