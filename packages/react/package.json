{
  "name": "@bubbly-design-system/react",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "keywords": [
    "bubbly-design-system",
    "bubbly-lab",
    "design-system"
  ],
  "homepage": "https://github.com/rumyscape/bubbly-design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rumyscape/bubbly-design-system.git",
    "directory": "packages/react"
  },
  "author": "@bubbly-lab/dev",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prepare": "panda codegen 2>/dev/null || true",
    "codegen": "panda codegen --clean",
    "build:js": "tsdown",
    "cssgen": "panda cssgen --outfile dist/styles.css --minify",
    "build": "pnpm codegen && pnpm build:js && pnpm cssgen",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@bubbly-design-system/icons": "^0.1.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^0.52.0",
    "@storybook/react": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.0",
    "tsdown": "^0.21.4",
    "vite": "^6.4.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
