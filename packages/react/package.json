{
  "name": "@bubbly-design-system/react",
  "version": "0.3.0",
  "description": "Bubbly Design System React components built on Panda CSS and Ark UI.",
  "type": "module",
  "keywords": [
    "bubbly-design-system",
    "bubbly-lab",
    "design-system",
    "react",
    "components",
    "panda-css",
    "ark-ui"
  ],
  "homepage": "https://github.com/bubbly-lab/bubbly-design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bubbly-lab/bubbly-design-system.git",
    "directory": "packages/react"
  },
  "author": "@bubbly-lab/dev",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prepare": "panda codegen 2>/dev/null || true",
    "codegen": "panda codegen --clean",
    "build:js": "tsdown",
    "cssgen": "panda cssgen --outfile dist/styles.css --minify",
    "build": "pnpm codegen && pnpm build:js && pnpm cssgen",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm codegen && storybook build",
    "test": "pnpm codegen && vitest run --project=storybook"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@bubbly-design-system/icons": "workspace:^"
  },
  "devDependencies": {
    "@bubbly-design-system/design-tokens": "workspace:^",
    "@pandacss/dev": "^0.52.0",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/addon-designs": "11.1.3",
    "@storybook/addon-docs": "10.4.2",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "playwright": "1.60.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.4.2",
    "tsdown": "^0.21.4",
    "vite": "^6.4.1",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
